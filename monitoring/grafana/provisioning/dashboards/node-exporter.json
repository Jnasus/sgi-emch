{
  "title": "SGI-EMCH — Servidor (node-exporter)",
  "uid": "sgi-node-exporter",
  "tags": ["sgi", "node-exporter", "infraestructura"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", instance=\"sgi-servidor\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "RAM Usada",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3221225472 },
              { "color": "red", "value": 6442450944 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"sgi-servidor\"} - node_memory_MemAvailable_bytes{instance=\"sgi-servidor\"}",
          "legendFormat": "RAM usada",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RAM Disponible",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "green", "value": 2147483648 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes{instance=\"sgi-servidor\"}",
          "legendFormat": "Disponible",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Disco Raíz Usado %",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{instance=\"sgi-servidor\", mountpoint=\"/\", fstype!=\"tmpfs\"} / node_filesystem_size_bytes{instance=\"sgi-servidor\", mountpoint=\"/\", fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "Disco /",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Uptime del Servidor",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdhms",
          "color": { "fixedColor": "green", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "expr": "node_time_seconds{instance=\"sgi-servidor\"} - node_boot_time_seconds{instance=\"sgi-servidor\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Load Average (1m)",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 4 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        {
          "expr": "node_load1{instance=\"sgi-servidor\"}",
          "legendFormat": "Load 1m",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage %",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\", instance=\"sgi-servidor\"}[5m])) * 100)",
          "legendFormat": "CPU total %",
          "refId": "A"
        },
        {
          "expr": "avg by(instance)(rate(node_cpu_seconds_total{mode=\"iowait\", instance=\"sgi-servidor\"}[5m])) * 100",
          "legendFormat": "iowait %",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memoria RAM",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"sgi-servidor\"}",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemTotal_bytes{instance=\"sgi-servidor\"} - node_memory_MemAvailable_bytes{instance=\"sgi-servidor\"}",
          "legendFormat": "Usada",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{instance=\"sgi-servidor\"}",
          "legendFormat": "Disponible",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Red — Tráfico de Entrada/Salida",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=\"sgi-servidor\", device!=\"lo\"}[5m])",
          "legendFormat": "Entrada — {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=\"sgi-servidor\", device!=\"lo\"}[5m])",
          "legendFormat": "Salida — {{device}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Disco — I/O (lectura/escritura)",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{instance=\"sgi-servidor\", device!~\"sr.*\"}[5m])",
          "legendFormat": "Lectura — {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{instance=\"sgi-servidor\", device!~\"sr.*\"}[5m])",
          "legendFormat": "Escritura — {{device}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Load Average",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "node_load1{instance=\"sgi-servidor\"}",
          "legendFormat": "1 min",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=\"sgi-servidor\"}",
          "legendFormat": "5 min",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=\"sgi-servidor\"}",
          "legendFormat": "15 min",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Uso de Disco por Partición",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus-sgi" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{instance=\"sgi-servidor\", fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{instance=\"sgi-servidor\", fstype!~\"tmpfs|overlay\"} * 100)",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ]
    }
  ]
}
